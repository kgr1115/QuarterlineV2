{
  "name": "quarterline-v2",
  "version": "0.1.0",
  "description": "Desktop CRE research and reporting platform",
  "main": "./out/main/index.js",
  "scripts": {
    "start": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder --win --config",
    "postinstall": "electron-builder install-app-deps",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "smoke-test": "electron-vite build && electron out/main/smoke-test.js"
  },
  "author": "Kyle Rauch",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "better-sqlite3": "^11.9.1",
    "csv-parse": "^6.2.1",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "leaflet": "^1.9.4",
    "marked": "^18.0.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-leaflet": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.2",
    "electron": "^36.3.1",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.27.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vite": "^6.3.5"
  }
